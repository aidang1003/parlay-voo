# === RPC ===

# Base Sepolia RPC endpoint. Consumed by foundry.toml and shared/chains.ts.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Same URL, re-exposed to the frontend (Next.js only bundles NEXT_PUBLIC_*).
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=

# === Keys ===

# Single signing key used by forge deploys and the settlement cron
# (/api/settlement/run). Required on Sepolia/mainnet. Leave blank
# locally — HelperConfig falls back to anvil account #0 and Deploy.s.sol
# auto-funds it. NEVER commit a real key.
DEPLOYER_PRIVATE_KEY=

# Optional. EIP-712 quote signer. Falls back to DEPLOYER_PRIVATE_KEY when
# unset (fine for local + testnet). On mainnet, set this separately so the
# signer can run hot while DEPLOYER_PRIVATE_KEY stays cold.
QUOTE_SIGNER_PRIVATE_KEY=


# === Addresses ===
# Used in forge funding script
USER_WALLET_ADDRESS=

# === Tokens ===

# Base Sepolia Circle USDC: 0x036CbD53842c5426634e7929541eC2318f3dCF7e.
# Leave blank for local dev (MockUSDC auto-deployed). All other contract
# addresses live in packages/nextjs/src/contracts/deployedContracts.ts
# (auto-generated by scripts/generate-deployed-contracts.ts).
USDC_ADDRESS=

# === Uniswap V3 (CreatePool.s.sol overrides) ===

# NonfungiblePositionManager on Base (same address on Sepolia + mainnet).
UNISWAP_NFPM=0x27F971cb582BF9E50F397e4d29a5C7A34f11faA2

# Canonical WETH on Base.
WETH_ADDRESS=0x4200000000000000000000000000000000000006

# === Polymarket ===

# Gamma (markets metadata). Default works in prod.
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# CLOB (orderbook). Default works in prod.
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# === Database / Cron ===

# Postgres connection string (required for DB-backed API routes).
DATABASE_URL=

# Shared secret for Vercel Cron routes (openssl rand -hex 32).
CRON_SECRET=

# === Contract Verification ===

# Basescan API key (used by agent-stats route).
BASESCAN_API_KEY=

# === Frontend ===

# 84532 = Base Sepolia, 31337 = Anvil. Controls which chain the app reads
# and writes against — see lib/hooks/_internal.ts.
NEXT_PUBLIC_CHAIN_ID=84532

# WalletConnect v2 project ID (wagmi.ts).
NEXT_PUBLIC_WC_PROJECT_ID=

# x402 payment header for premium endpoints (default: "demo-token" in dev).
NEXT_PUBLIC_X402_PAYMENT=demo-token
