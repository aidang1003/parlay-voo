{
  "name": "parlaycity",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm -r lint",
    "typecheck": "cd packages/nextjs && npx tsc --noEmit",
    "test": "pnpm test:contracts && pnpm test:web",
    "test:contracts": "cd packages/foundry && forge test -vvv",
    "test:web": "pnpm --filter web test",
    "chain": "cd packages/foundry && anvil",
    "deploy": "cd packages/foundry && forge script script/Deploy.s.sol --broadcast --rpc-url http://127.0.0.1:8545"
  },
  "pnpm": {
    "overrides": {
      "wagmi": "^2.14.0",
      "viem": "^2.21.0",
      "@tanstack/react-query": "^5.62.0"
    }
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
