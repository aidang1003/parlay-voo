{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.ts",
        "scripts/lib/*.ts"
      ],
      "project": [
        "scripts/**/*.ts"
      ]
    },
    "packages/nextjs": {
      "vitest": false,
      "entry": [
        "src/app/**/{page,layout,route,loading,error,not-found,template,default}.{ts,tsx,js,jsx}",
        "src/app/**/opengraph-image.{ts,tsx}",
        "src/app/**/icon.{ts,tsx}",
        "src/app/**/sitemap.{ts,tsx}",
        "src/app/**/robots.{ts,tsx}",
        "src/middleware.{ts,js}",
        "next.config.{js,mjs,ts}",
        "tailwind.config.{js,ts}",
        "postcss.config.{js,cjs}",
        "src/test/**/*.{ts,tsx}",
        "src/**/__tests__/**/*.{ts,tsx}",
        "src/**/*.test.{ts,tsx}"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ],
      "ignore": [
        "src/contracts/deployedContracts.ts",
        "src/contracts/deployments/**"
      ],
      "ignoreDependencies": []
    },
    "packages/shared": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    }
  }
}
