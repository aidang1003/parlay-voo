# Contract addresses (deployed on Base Sepolia or localhost)
NEXT_PUBLIC_HOUSE_VAULT_ADDRESS=
NEXT_PUBLIC_PARLAY_ENGINE_ADDRESS=
NEXT_PUBLIC_LEG_REGISTRY_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_ADMIN_ORACLE_ADDRESS=
ADMIN_ORACLE_ADDRESS=

# WalletConnect project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Neon Postgres (create a project at neon.tech, use the pooled connection string)
DATABASE_URL=

# Shared secret for cron-protected routes: /api/polymarket/sync, /api/db/init.
# Only enforced when running on Vercel (VERCEL=1). Local dev bypasses it.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Polymarket API overrides (defaults work for production)
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
