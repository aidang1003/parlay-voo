# =============================================================================
# Single source of truth for environment variables across the monorepo.
# Per-package files (packages/foundry/.env, packages/nextjs/.env.local) are
# symlinks to this file, installed by `pnpm install` via scripts/setup-env.sh.
# Edit only this file. Do not create real per-package envs — they will drift.
# =============================================================================

# === RPC ===

# Single Alchemy key drives every non-local chain (Mainnet, Sepolia, Base,
# Base Sepolia). Get a free key at https://dashboard.alchemy.com. Anvil
# local is the only hardcoded RPC.
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Optional per-chain overrides. When set, takes precedence over the Alchemy
# URL for that chain. Useful if you want to use Infura/QuickNode/your own
# node for a specific network. Leave blank to use Alchemy.
NEXT_PUBLIC_MAINNET_RPC_URL=
NEXT_PUBLIC_SEPOLIA_RPC_URL=
NEXT_PUBLIC_BASE_MAINNET_RPC_URL=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=



# === Keys ===

# Signs forge deploys and the settlement cron.
# Optional on Anvil local.
WARM_DEPLOYER_PRIVATE_KEY=

# Signs price quotes for ticket purchases.
# Optional on Anvil local.
HOT_SIGNER_PRIVATE_KEY=



# === Polymarket ===

# Gamma (markets metadata). Default works in prod.
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# CLOB (orderbook). Default works in prod.
POLYMARKET_CLOB_URL=https://clob.polymarket.com



# === Database / Cron ===

# Postgres connection string (required for DB-backed API routes).
# Supabase: dashboard → Project Settings → Database → Connection string → "Transaction pooler" (port 6543, IPv4-friendly, best for Vercel serverless).
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Shared secret for Vercel Cron routes (openssl rand -hex 32).
CRON_SECRET=



# === Contract Verification ===

# Single Etherscan key covers Mainnet/Sepolia/Base/Base Sepolia verification + the agent-stats route.
# Get a free key at https://etherscan.io/myapikey.
ETHERSCAN_API_KEY=



# === Frontend ===

# 84532 = Base Sepolia, 31337 = Anvil. Controls which chain the app reads
# and writes against — see lib/hooks/_internal.ts.
NEXT_PUBLIC_CHAIN_ID=84532

# WalletConnect v2 project ID (wagmi.ts).
NEXT_PUBLIC_WC_PROJECT_ID=



# === Protocol Parameters ===
# See docs/ARCHITECTURE.md and docs/changes/CORRELATION.md.

# Per-leg fee in BPS. Applied as (1 - f) per leg before correlation. 1000 = 10%.
NEXT_PUBLIC_PROTOCOL_FEE_BPS=1000

# Correlation D: asymptotic discount ceiling in BPS. 8000 = 80%.
NEXT_PUBLIC_CORRELATION_ASYMPTOTE_BPS=4000

# Correlation k × 1e6: half-saturation point in PPM. 1_000_000 = k=1.0.
NEXT_PUBLIC_CORRELATION_HALF_SAT_PPM=1200000

# Hard cap on legs from one correlation group (builder-side gate).
NEXT_PUBLIC_MAX_LEGS_PER_GROUP=3



# === Optional helpers ===

# Wallet where funds in `pnpm fund-wallet:<netowrk> <fund>` will go
USER_WALLET_ADDRESS=

# When True, `pnpm deploy:*` uses the chain's canonical Circle USDC
# When False, `pnpm deploy:*` deploys a MockUSDC to spoof USDC for the protocol
USE_REAL_USDC=false
