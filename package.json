{
  "name": "parlayvoo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "account": "pnpm --filter @se-2/foundry account",
    "account:generate": "pnpm --filter @se-2/foundry account:generate",
    "account:import": "pnpm --filter @se-2/foundry account:import",
    "account:reveal-pk": "pnpm --filter @se-2/foundry account:reveal-pk",
    "chain": "pnpm --filter @se-2/foundry chain",
    "compile": "pnpm --filter @se-2/foundry compile",
    "deploy": "pnpm --filter @se-2/foundry deploy",
    "deploy:local": "pnpm --filter @se-2/foundry deploy:local",
    "deploy:sepolia": "pnpm --filter @se-2/foundry deploy:sepolia",
    "next:clean": "pnpm --filter @se-2/nextjs clean",
    "redeploy:local": "pnpm foundry:clean && pnpm next:clean && pnpm deploy:local",
    "nuke": "pnpm --filter @se-2/foundry nuke && pnpm next:clean",
    "fund-wallet:local": "pnpm --filter @se-2/foundry fund-wallet:local",
    "fund-wallet:sepolia": "pnpm --filter @se-2/foundry fund-wallet:sepolia",
    "resolve-leg:local": "pnpm --filter @se-2/foundry resolve-leg:local",
    "resolve-leg:sepolia": "pnpm --filter @se-2/foundry resolve-leg:sepolia",
    "flatten": "pnpm --filter @se-2/foundry flatten",
    "fork": "pnpm --filter @se-2/foundry fork",
    "format": "pnpm next:format && pnpm foundry:format",
    "foundry:format": "pnpm --filter @se-2/foundry format",
    "foundry:lint": "pnpm --filter @se-2/foundry lint",
    "foundry:test": "pnpm --filter @se-2/foundry test",
    "foundry:test:fork": "pnpm --filter @se-2/foundry test:fork",
    "foundry:verify": "pnpm --filter @se-2/foundry verify",
    "foundry:clean": "pnpm --filter @se-2/foundry clean",
    "generate": "pnpm --filter @se-2/foundry account:generate",
    "ipfs": "pnpm --filter @se-2/nextjs ipfs",
    "lint": "pnpm next:lint && pnpm foundry:lint",
    "next:build": "pnpm --filter @se-2/nextjs build",
    "next:check-types": "pnpm --filter @se-2/nextjs check-types",
    "next:format": "pnpm --filter @se-2/nextjs format",
    "next:lint": "pnpm --filter @se-2/nextjs lint",
    "next:serve": "pnpm --filter @se-2/nextjs serve",
    "test": "pnpm foundry:test && pnpm test:web",
    "test:web": "pnpm --filter @se-2/nextjs test",
    "typecheck": "pnpm next:check-types",
    "build": "dotenv -c -- pnpm --filter @se-2/nextjs build",
    "start": "dotenv -c -- pnpm --filter @se-2/nextjs start",
    "serve": "dotenv -c -- pnpm --filter @se-2/nextjs serve",
    "dev": "dotenv -c -- pnpm --filter @se-2/nextjs dev",
    "gate": "pnpm test && pnpm typecheck && pnpm build",
    "vercel": "pnpm --filter @se-2/nextjs vercel",
    "vercel:login": "pnpm --filter @se-2/nextjs vercel:login",
    "vercel:yolo": "pnpm --filter @se-2/nextjs vercel:yolo",
    "verify": "pnpm foundry:verify",
    "precommit": "lint-staged",
    "prepare": "husky",
    "setup:env": "bash scripts/setup-env.sh",
    "postinstall": "pnpm setup:env",
    "predev": "pnpm setup:env",
    "prestart": "pnpm setup:env",
    "prebuild": "pnpm setup:env",
    "predeploy": "pnpm setup:env",
    "predeploy:local": "pnpm setup:env",
    "predeploy:sepolia": "pnpm setup:env"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "husky": "~9.1.6",
    "lint-staged": "~13.2.2"
  },
  "lint-staged": {
    "packages/nextjs/**/*.{js,jsx,ts,tsx}": "pnpm --filter @se-2/nextjs exec eslint --fix --max-warnings=0",
    "packages/foundry/**/*.sol": "pnpm --filter @se-2/foundry exec forge fmt"
  },
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=20.18.3",
    "pnpm": ">=8"
  }
}
