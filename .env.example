# === Chain ===
# Base Sepolia RPC
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Local Anvil
LOCAL_RPC_URL=http://127.0.0.1:8545
# Deployer private key (NEVER commit real keys)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Deployer address (derived from DEPLOYER_PRIVATE_KEY; for reference only)
DEPLOYER_ADDRESS=
# Second account key (for demo-seed.sh Sepolia mode)
ACCOUNT1_PRIVATE_KEY=

# === USDC ===
# Base Sepolia Circle USDC: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Leave blank for local dev (MockUSDC auto-deployed). All other contract
# addresses are written to packages/nextjs/.env.local by
# `tsx scripts/sync-env.ts` after deploy — do not store them here.
USDC_ADDRESS=

# === Frontend secrets forwarded to packages/nextjs/.env.local by sync-env.ts ===
DATABASE_URL=
# openssl rand -hex 32
CRON_SECRET=
QUOTE_SIGNER_PRIVATE_KEY=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=

# === Polymarket (optional overrides; defaults work in prod) ===
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# === Contract Verification ===
BASESCAN_API_KEY=

# === Uniswap V3 (Base Sepolia defaults) ===
UNISWAP_NFPM=0x27F971cb582BF9E50F397e4d29a5C7A34f11faA2
UNISWAP_SWAP_ROUTER=0x94cC0AaC535CCDB3C01d6787D6413C739ae12bc4
WETH_ADDRESS=0x4200000000000000000000000000000000000006

# === Services ===
CATALOG_PORT=3001
QUOTE_PORT=3002
HEDGER_PORT=3003

# === Frontend ===
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# === Frontend (optional) ===
# Services API URL for risk advisor (default: http://localhost:3001)
NEXT_PUBLIC_SERVICES_URL=http://localhost:3001
# x402 payment header for premium endpoints (default: "demo-token" in dev)
NEXT_PUBLIC_X402_PAYMENT=demo-token

# === MCP / Verifier ===
MISTRAL_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=
CODESTRAL_API_KEY=

# === x402 ===
X402_RECIPIENT_WALLET=
# Network: "eip155:84532" (Base Sepolia, default) or "eip155:8453" (Base mainnet)
X402_NETWORK=eip155:84532
# Facilitator URL (default: https://facilitator.x402.org)
X402_FACILITATOR_URL=https://facilitator.x402.org
# Price per premium sim request (default: $0.01)
X402_PRICE='$0.01'
# Set to "true" to force stub mode in production (disables payment verification)
# X402_STUB=
