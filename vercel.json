{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @se-2/nextjs build",
  "outputDirectory": "packages/nextjs/.next",
  "crons": [
    {
      "path": "/api/polymarket/sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/settlement/run",
      "schedule": "0 20 * * *"
    }
  ]
}